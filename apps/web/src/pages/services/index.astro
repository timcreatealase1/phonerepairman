---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import Eyebrow from '~/components/Eyebrow.astro';
import Icon from '~/components/Icon.astro';
import { site, services } from '~/data/site';
import { serviceDetails } from '~/data/serviceDetails';
import { breadcrumbSchema, serviceSchema } from '~/lib/seo/schema';

const title = `Services — ${site.name}`;
const description =
  'Phone, laptop, tablet, gaming console and onsite business IT repair in Muswellbrook. Authorised Agent for HP, Acer and Lexmark — direct Epson partner.';

const breadcrumbs = [
  { name: 'Home',     href: site.url },
  { name: 'Services', href: `${site.url}/services/` },
];

const schemaNodes = [
  breadcrumbSchema(breadcrumbs),
  ...services.map((s) =>
    serviceSchema({
      name: s.name,
      description: serviceDetails[s.slug]?.lede ?? s.short,
      serviceType: s.name,
      url: `${site.url}/services/${s.slug}`,
    }),
  ),
];
---

<BaseLayout title={title} description={description} schemaNodes={schemaNodes}>
  <Breadcrumb items={[{ name: 'Home', href: '/' }, { name: 'Services' }]} />

  {/* HERO */}
  <section class="bg-paper">
    <div class="container-x py-14 lg:py-20">
      <div class="max-w-3xl">
        <Eyebrow>What we fix</Eyebrow>
        <h1 class="mt-4 display-1 text-ink-900">
          Five services. One workshop. Every brand.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-700">
          We repair phones, laptops, tablets and gaming consoles in our Bridge Street shop —
          and run onsite IT for businesses across the Hunter. AWA-authorised for HP, Acer and
          Lexmark; direct Epson partner.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={site.phone.href} class="btn btn-primary">
            <Icon name="phone" size={18} /> Call {site.phone.display}
          </a>
          <a href={site.sms.href} class="btn btn-outline">
            <Icon name="message-circle" size={18} /> SMS us
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* SERVICES LIST — editorial rows, one per service */}
  <section class="bg-paper pb-16">
    <div class="container-x">
      <ul class="divide-y divide-line border-y border-line">
        {services.map((s, i) => {
          const detail = serviceDetails[s.slug];
          return (
            <li>
              <a
                href={`/services/${s.slug}`}
                class="group grid gap-6 py-10 transition lg:grid-cols-[auto,1fr,auto] lg:items-start lg:gap-12"
              >
                <span class="font-mono text-sm font-medium uppercase tracking-[0.18em] text-brand-500 lg:w-12">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <div>
                  <h2 class="display-2 text-ink-900 group-hover:text-brand-700">{s.name}</h2>
                  <p class="mt-3 max-w-2xl text-[1.05rem] leading-relaxed text-ink-700">
                    {detail?.lede ?? s.short}
                  </p>
                  {detail && (
                    <p class="mt-4 font-mono text-xs uppercase tracking-wider text-ink-500">
                      {detail.devices.slice(0, 6).join(' · ')}
                    </p>
                  )}
                </div>
                <span class="hidden lg:inline-flex h-11 w-11 items-center justify-center rounded-full border border-ink-900/15 text-ink-700 transition group-hover:border-brand-500 group-hover:bg-brand-500 group-hover:text-white">
                  <Icon name="arrow-right" size={18} />
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </section>

  {/* AUTHORISATIONS STRIP */}
  <section class="section bg-white">
    <div class="container-x grid gap-10 lg:grid-cols-[1fr,1.2fr] lg:items-start lg:gap-16">
      <div>
        <Eyebrow>Brand authorisations</Eyebrow>
        <h2 class="mt-3 display-2 text-ink-900">Authorised, not just available.</h2>
        <p class="mt-4 text-ink-700">
          Warranty work for these brands routes through Phone Repairman via the
          AWA / ARA partner network — same coverage as factory service, no parcel
          shipping out of the Hunter.
        </p>
      </div>
      <ul class="grid gap-3 sm:grid-cols-2">
        {site.authorizations.map((a) => (
          <li class="flex items-start gap-4 rounded-md border border-line bg-paper p-5">
            <span class="mt-0.5 text-brand-500"><Icon name="shield-check" size={22} /></span>
            <div>
              <p class="text-lg font-bold text-ink-900">{a.brand}</p>
              <p class="mt-0.5 font-mono text-xs uppercase tracking-wider text-ink-600">{a.kind}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* CLOSING CTA */}
  <section class="bg-paper border-t border-line">
    <div class="container-x py-14 text-center">
      <Eyebrow>Drop in, send it in, or book us onsite</Eyebrow>
      <h2 class="mt-3 display-2 text-ink-900">
        {site.address.street}, {site.address.suburb} · {site.hoursDisplay[0].value}
      </h2>
      <div class="mt-8 inline-flex flex-wrap justify-center gap-3">
        <a href={site.phone.href} class="btn btn-primary">
          <Icon name="phone" size={18} /> Call {site.phone.display}
        </a>
        <a href="/contact" class="btn btn-outline">
          <Icon name="map-pin" size={18} /> Contact &amp; directions
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
