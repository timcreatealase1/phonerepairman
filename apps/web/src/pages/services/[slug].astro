---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import Eyebrow from '~/components/Eyebrow.astro';
import MonoLabel from '~/components/MonoLabel.astro';
import PhotoSlot from '~/components/PhotoSlot.astro';
import Icon from '~/components/Icon.astro';
import { site, services, serviceBySlug } from '~/data/site';
import { serviceDetails } from '~/data/serviceDetails';
import { breadcrumbSchema, serviceSchema, faqPageSchema } from '~/lib/seo/schema';

export function getStaticPaths() {
  return services.map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const service = serviceBySlug(slug!);
const detail = serviceDetails[slug!];

if (!service || !detail) {
  return Astro.redirect('/services/');
}

const title = `${service.name} in Muswellbrook — ${site.name}`;
const description = detail.lede.slice(0, 155);

const breadcrumbs = [
  { name: 'Home',         href: site.url },
  { name: 'Services',     href: `${site.url}/services/` },
  { name: service.name,   href: `${site.url}/services/${slug}` },
];

const schemaNodes = [
  breadcrumbSchema(breadcrumbs),
  serviceSchema({
    name: service.name,
    description: detail.lede,
    serviceType: service.name,
    url: `${site.url}/services/${slug}`,
  }),
  faqPageSchema(detail.faqs),
];

const relatedServices = detail.related
  .map((s) => services.find((x) => x.slug === s))
  .filter((s): s is NonNullable<typeof s> => Boolean(s));
---

<BaseLayout title={title} description={description} schemaNodes={schemaNodes}>
  <Breadcrumb items={[{ name: 'Home', href: '/' }, { name: 'Services', href: '/services/' }, { name: service.name }]} />

  {/* HERO — text + photo */}
  <section class="bg-paper">
    <div class="container-x grid items-center gap-12 py-12 lg:grid-cols-[1.15fr,1fr] lg:gap-16 lg:py-20">
      <div>
        <Eyebrow>Service · {String(services.findIndex((s) => s.slug === slug) + 1).padStart(2, '0')}</Eyebrow>
        <h1 class="mt-4 display-1 text-ink-900">{service.name} in Muswellbrook.</h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-700">{detail.lede}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={site.phone.href} class="btn btn-primary">
            <Icon name="phone" size={18} /> Call {site.phone.display}
          </a>
          <a href={site.sms.href} class="btn btn-outline">
            <Icon name="message-circle" size={18} /> SMS for a quote
          </a>
        </div>
        <ul class="mt-10 grid gap-3 sm:grid-cols-2 sm:gap-x-8">
          <MonoLabel>Walk-in + onsite</MonoLabel>
          <MonoLabel>{site.address.street}, {site.address.suburb}</MonoLabel>
          <MonoLabel>{site.phone.display}</MonoLabel>
          <MonoLabel>Est. {site.yearFounded}</MonoLabel>
        </ul>
      </div>
      <div>
        <PhotoSlot
          alt={`${service.name} bench at Phone Repairman, Muswellbrook`}
          aspect="4/5"
          tag={`${String(services.findIndex((s) => s.slug === slug) + 1).padStart(2, '0')} · ${service.name}`}
          loading="eager"
        />
      </div>
    </div>
  </section>

  {/* WHAT WE FIX */}
  <section class="section bg-paper border-t border-line">
    <div class="container-x">
      <div class="mb-10 max-w-2xl">
        <Eyebrow>What we fix</Eyebrow>
        <h2 class="mt-3 display-2 text-ink-900">Common faults, sorted in-house.</h2>
      </div>
      <ul class="grid gap-px overflow-hidden rounded-md border border-line bg-line sm:grid-cols-2">
        {detail.whatWeFix.map((item, i) => (
          <li class="bg-paper p-6">
            <p class="font-mono text-xs uppercase tracking-[0.18em] text-brand-500">
              {String(i + 1).padStart(2, '0')}
            </p>
            <p class="mt-2 text-lg font-bold text-ink-900">{item.title}</p>
            <p class="mt-2 text-base leading-relaxed text-ink-700">{item.description}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* DEVICES + TURNAROUND + WARRANTY */}
  <section class="section bg-white">
    <div class="container-x grid gap-10 lg:grid-cols-3 lg:gap-16">
      <div>
        <Eyebrow>Brands and devices</Eyebrow>
        <h3 class="mt-3 text-xl font-bold text-ink-900">If it has a screen, we probably fix it.</h3>
        <ul class="mt-5 flex flex-wrap gap-2">
          {detail.devices.map((d) => (
            <li class="rounded-full border border-ink-900/15 bg-paper px-3 py-1 text-sm font-medium text-ink-900">
              {d}
            </li>
          ))}
        </ul>
      </div>
      <div>
        <Eyebrow>Turnaround</Eyebrow>
        <h3 class="mt-3 text-xl font-bold text-ink-900">Written timing at drop-off.</h3>
        <p class="mt-3 text-ink-700">{detail.turnaround}</p>
      </div>
      <div>
        <Eyebrow>Warranty</Eyebrow>
        <h3 class="mt-3 text-xl font-bold text-ink-900">Quoted in writing, every time.</h3>
        <p class="mt-3 text-ink-700">{detail.warranty}</p>
      </div>
    </div>
  </section>

  {/* FAQ */}
  <section class="section bg-paper">
    <div class="container-x grid gap-12 lg:grid-cols-[1fr,1.5fr] lg:items-start lg:gap-16">
      <div class="lg:sticky lg:top-24">
        <Eyebrow>Service FAQ</Eyebrow>
        <h2 class="mt-3 display-2 text-ink-900">A few quick answers.</h2>
        <p class="mt-4 text-ink-700">
          Still stuck? <a href={site.phone.href} class="font-semibold text-brand-500 hover:underline">Call us</a>
          or <a href="/faqs" class="font-semibold text-brand-500 hover:underline">see all FAQs</a>.
        </p>
      </div>
      <div class="divide-y divide-line rounded-md border border-line bg-white">
        {detail.faqs.map((f, i) => (
          <details class="group p-6" open={i === 0}>
            <summary class="flex cursor-pointer list-none items-baseline gap-4">
              <span class="shrink-0 font-mono text-xs font-medium uppercase tracking-wider text-brand-500">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class="flex-1 text-lg font-bold text-ink-900">{f.question}</span>
              <span class="shrink-0 text-brand-500 transition group-open:rotate-90"><Icon name="chevron-right" size={18} /></span>
            </summary>
            <p class="mt-4 ml-9 leading-relaxed text-ink-700">{f.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* RELATED SERVICES */}
  <section class="section bg-white">
    <div class="container-x">
      <Eyebrow>Related services</Eyebrow>
      <h2 class="mt-3 display-2 text-ink-900">Also handled in-house.</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        {relatedServices.map((r) => (
          <a
            href={`/services/${r.slug}`}
            class="group rounded-md border border-line bg-paper p-6 transition hover:border-brand-200 hover:bg-white"
          >
            <Icon name={r.icon as any} size={22} class="text-brand-500" />
            <p class="mt-4 text-lg font-bold text-ink-900">{r.name}</p>
            <p class="mt-2 text-sm leading-relaxed text-ink-700">{r.short}</p>
            <p class="mt-4 inline-flex items-center gap-1 font-mono text-xs uppercase tracking-wider text-brand-500 group-hover:gap-2 transition-all">
              View service <Icon name="arrow-right" size={12} />
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* CLOSING CTA */}
  <section class="bg-brand-900 text-white">
    <div class="container-x py-14 text-center">
      <p class="eyebrow-on-dark">Bring it in, send it in, or book us onsite</p>
      <h2 class="mt-3 display-2">{service.name} in {site.address.suburb} — start here.</h2>
      <div class="mt-8 inline-flex flex-wrap justify-center gap-3">
        <a href={site.phone.href} class="btn btn-white">
          <Icon name="phone" size={18} /> {site.phone.display}
        </a>
        <a href={site.sms.href} class="btn btn-outline-white">
          <Icon name="message-circle" size={18} /> SMS for a quote
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
