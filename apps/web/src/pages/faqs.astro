---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import Eyebrow from '~/components/Eyebrow.astro';
import Icon from '~/components/Icon.astro';
import { site } from '~/data/site';
import { breadcrumbSchema, faqPageSchema } from '~/lib/seo/schema';

const title = `FAQs — ${site.name}`;
const description = `Common questions about device repairs at ${site.name}: walk-ins, turnaround, parts, warranty, AWA / ARA authorisations, business services.`;

const breadcrumbs = [
  { name: 'Home', href: site.url },
  { name: 'FAQs', href: `${site.url}/faqs` },
];

const groups = [
  {
    label: 'General',
    items: [
      {
        question: 'Do I need to book, or can I just walk in?',
        answer:
          'Walk-ins are welcome any time during opening hours. For laptops, gaming consoles and warranty work it helps to call ahead — that way we know parts are in stock and can usually book you in for a same-day return.',
      },
      {
        question: 'When are you open?',
        answer:
          'Monday to Friday, 9:30am to 5:00pm. Closed weekends and public holidays. For urgent business calls outside hours, call directly and we will work something out.',
      },
      {
        question: 'Where are you?',
        answer: `${site.address.street}, ${site.address.suburb} NSW ${site.address.postcode} — ${site.address.note}.`,
      },
      {
        question: 'What payment methods do you accept?',
        answer: `${site.paymentAccepted.join(', ')}. Pick whatever suits.`,
      },
    ],
  },
  {
    label: 'Repairs',
    items: [
      {
        question: 'How long does a repair take?',
        answer:
          'Most common phone repairs (screen, battery, charging port) are completed same-day when the part is in stock. Laptops and gaming consoles are typically 1–3 business days. We give you a written turnaround on drop-off.',
      },
      {
        question: 'Do you use genuine parts?',
        answer:
          'For brands where we are an authorised agent (HP, Acer, Lexmark, Epson), warranty repairs use genuine OEM parts. For other brands and out-of-warranty work we use genuine where available, quality aftermarket otherwise — and we tell you which before doing the work.',
      },
      {
        question: 'What is the warranty on a repair?',
        answer:
          'Repairs are covered by a workmanship warranty quoted in writing at drop-off. Parts warranty depends on the source. AWA warranty repairs carry the original manufacturer warranty.',
      },
      {
        question: 'Will a screen replacement wipe my data?',
        answer:
          "No. Most repairs don't touch your storage. We do recommend a recent backup before any repair, just in case a device needs further work.",
      },
      {
        question: 'My device is water-damaged. What now?',
        answer:
          "Power it off, do not plug it in to charge, and bring it in as soon as you can. Sooner = better chance of full recovery. Rice doesn't help.",
      },
    ],
  },
  {
    label: 'Authorisations',
    items: [
      {
        question: 'Are you actually authorised to repair HP, Acer, Lexmark and Epson?',
        answer:
          'Yes. Phone Repairman is an AWA-authorised service agent for HP, Acer and Lexmark, and a direct service partner with Epson. Warranty work for these brands routes through us via ARA/AWA — same coverage as factory service, no parcel shipping out of the Hunter.',
      },
      {
        question: 'What does "AWA-authorised" actually mean?',
        answer:
          'AWA (Authorised Warranty Agent) is the partner network the OEMs use to deliver warranty service locally. For customers it means: same warranty cover as if you bought direct from HP, Acer or Lexmark, with parts ordered through the OEM channel and an open escalation line back to the manufacturer if something is unusual.',
      },
      {
        question: 'Can I get warranty work done here instead of shipping interstate?',
        answer:
          'Yes — for HP, Acer, Lexmark and Epson. Bring the machine in, we lodge the warranty claim and complete the repair locally. No couriers, no missing-in-transit, no waiting weeks.',
      },
    ],
  },
  {
    label: 'Business and onsite',
    items: [
      {
        question: 'Do you do onsite service?',
        answer:
          'Yes — for businesses across the Upper Hunter. Workstations, printers, network, point of sale, fleet device repair. Bookable per visit or under a partner agreement for ongoing work.',
      },
      {
        question: "We're an MSP. Can you subcontract for us?",
        answer:
          'Yes. We act as the field-service arm for MSPs running customers in the Hunter — white-label or co-branded. Call Tim directly to set up an agreement.',
      },
      {
        question: 'Can you supply and service mining IT fleet?',
        answer:
          'Yes. Phone Repairman supplies, repairs and onsite-services fleet devices for mining IT — phones, ruggedised laptops, printers. Quoted per scope.',
      },
    ],
  },
];

const allFaqs = groups.flatMap((g) => g.items);
const schemaNodes = [breadcrumbSchema(breadcrumbs), faqPageSchema(allFaqs)];
---

<BaseLayout title={title} description={description} schemaNodes={schemaNodes}>
  <Breadcrumb items={[{ name: 'Home', href: '/' }, { name: 'FAQs' }]} />

  {/* HERO */}
  <section class="bg-paper">
    <div class="container-x py-14 lg:py-20">
      <div class="max-w-3xl">
        <Eyebrow>Frequently asked</Eyebrow>
        <h1 class="mt-4 display-1 text-ink-900">
          Common questions, plain answers.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-700">
          Most of what people ring to ask, written down. If your question isn't here,
          <a href={site.phone.href} class="font-semibold text-brand-500 hover:underline">call us</a> —
          chances are we can sort it on the phone.
        </p>
      </div>
    </div>
  </section>

  {/* FAQ GROUPS */}
  <section class="section bg-paper">
    <div class="container-x space-y-16">
      {groups.map((g) => (
        <div class="grid gap-8 lg:grid-cols-[1fr,2fr] lg:gap-16">
          <div class="lg:sticky lg:top-24 lg:self-start">
            <Eyebrow>{g.label}</Eyebrow>
            <h2 class="mt-3 display-2 text-ink-900">{g.label}</h2>
            <p class="mt-3 font-mono text-xs uppercase tracking-wider text-ink-600">
              {g.items.length} question{g.items.length === 1 ? '' : 's'}
            </p>
          </div>
          <div class="divide-y divide-line rounded-md border border-line bg-white">
            {g.items.map((f, i) => (
              <details class="group p-6" open={false}>
                <summary class="flex cursor-pointer list-none items-baseline gap-4">
                  <span class="shrink-0 font-mono text-xs font-medium uppercase tracking-wider text-brand-500">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <span class="flex-1 text-lg font-bold text-ink-900">{f.question}</span>
                  <span class="shrink-0 text-brand-500 transition group-open:rotate-90"><Icon name="chevron-right" size={18} /></span>
                </summary>
                <p class="mt-4 ml-9 leading-relaxed text-ink-700">{f.answer}</p>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  {/* CLOSING CTA */}
  <section class="bg-brand-900 text-white">
    <div class="container-x py-14 text-center">
      <p class="eyebrow-on-dark">Didn't find your answer?</p>
      <h2 class="mt-3 display-2">Just ring us — {site.phone.display}.</h2>
      <div class="mt-8 inline-flex flex-wrap justify-center gap-3">
        <a href={site.phone.href} class="btn btn-white">
          <Icon name="phone" size={18} /> Call
        </a>
        <a href={site.sms.href} class="btn btn-outline-white">
          <Icon name="message-circle" size={18} /> SMS
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
