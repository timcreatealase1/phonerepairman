---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumb from '~/components/Breadcrumb.astro';
import Eyebrow from '~/components/Eyebrow.astro';
import Icon from '~/components/Icon.astro';
import { site } from '~/data/site';
import { locations } from '~/data/locations';
import { breadcrumbSchema } from '~/lib/seo/schema';

const title = `Where we service — ${site.name}`;
const description =
  'Phone Repairman serves Muswellbrook, Singleton, Scone, Aberdeen, Denman, Merriwa, Murrurundi and the broader Hunter Valley — walk-in at Bridge Street or book us onsite.';

const breadcrumbs = [
  { name: 'Home',      href: site.url },
  { name: 'Locations', href: `${site.url}/locations/` },
];

const schemaNodes = [breadcrumbSchema(breadcrumbs)];

const towns = locations.filter((l) => l.kind === 'town');
const regions = locations.filter((l) => l.kind === 'region');
---

<BaseLayout title={title} description={description} schemaNodes={schemaNodes}>
  <Breadcrumb items={[{ name: 'Home', href: '/' }, { name: 'Locations' }]} />

  {/* HERO */}
  <section class="bg-paper">
    <div class="container-x py-14 lg:py-20">
      <div class="max-w-3xl">
        <Eyebrow>Where we service</Eyebrow>
        <h1 class="mt-4 font-blackout text-display-1 leading-[0.95] tracking-tight">
          <span class="text-ink-900">UPPER HUNTER.</span>{' '}
          <span class="text-brand-500">EVERY POSTCODE.</span>
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-700">
          Walk in at 22 Bridge Street, Muswellbrook. Drop your device off any time
          you're passing through. For business customers we run onsite IT and repair
          calls across the Upper Hunter — Muswellbrook, Singleton, Scone, Aberdeen,
          Denman, Merriwa, Murrurundi, plus the broader Hunter Valley.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={site.phone.href} class="btn btn-primary">
            <Icon name="phone" size={18} /> Call {site.phone.display}
          </a>
          <a href={site.address.directions} target="_blank" rel="noopener" class="btn btn-outline">
            <Icon name="directions" size={18} /> Directions
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* TOWNS LIST */}
  <section class="section bg-paper">
    <div class="container-x">
      <div class="mb-10 max-w-2xl">
        <Eyebrow>Towns we serve</Eyebrow>
        <h2 class="mt-3 display-2 text-ink-900">Seven towns. One workshop.</h2>
      </div>
      <ul class="divide-y divide-line border-y border-line">
        {towns.map((l, i) => (
          <li>
            <a
              href={`/locations/${l.slug}`}
              class="group grid items-start gap-6 py-8 transition lg:grid-cols-[auto,1fr,auto,auto] lg:gap-12"
            >
              <span class="font-mono text-sm font-medium uppercase tracking-[0.18em] text-brand-500 lg:w-12">
                {String(i + 1).padStart(2, '0')}
              </span>
              <div>
                <h3 class="text-2xl sm:text-3xl font-bold text-ink-900 group-hover:text-brand-700">{l.name}</h3>
                <p class="mt-2 max-w-2xl text-ink-700">{l.short}</p>
              </div>
              <div class="text-left lg:text-right">
                {l.distanceKm != null && (
                  <p class="font-mono text-xs uppercase tracking-wider text-ink-500">
                    {l.distanceKm} km {l.direction}
                  </p>
                )}
                {l.driveTime && (
                  <p class="mt-1 font-mono text-xs uppercase tracking-wider text-ink-500">
                    {l.driveTime}
                  </p>
                )}
                {l.direction === 'home' && (
                  <p class="font-mono text-xs uppercase tracking-wider text-brand-500">
                    Our shop
                  </p>
                )}
              </div>
              <span class="hidden lg:inline-flex h-11 w-11 items-center justify-center rounded-full border border-line-strong text-ink-700 transition group-hover:border-brand-500 group-hover:bg-brand-500 group-hover:text-white">
                <Icon name="arrow-right" size={18} />
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* REGIONS */}
  {regions.length > 0 && (
    <section class="section bg-white border-t border-line">
      <div class="container-x">
        <div class="mb-10 max-w-2xl">
          <Eyebrow>Regional umbrella</Eyebrow>
          <h2 class="mt-3 display-2 text-ink-900">The wider Hunter Valley.</h2>
        </div>
        <ul class="grid gap-4 sm:grid-cols-2">
          {regions.map((l) => (
            <li>
              <a
                href={`/locations/${l.slug}`}
                class="group flex items-start gap-4 rounded-md border border-line bg-paper p-6 transition hover:border-brand-200 hover:bg-white"
              >
                <span class="mt-0.5 text-brand-500"><Icon name="map-pin" size={22} /></span>
                <div class="flex-1">
                  <h3 class="text-lg font-bold text-ink-900 group-hover:text-brand-700">{l.name}</h3>
                  <p class="mt-1 text-sm text-ink-700">{l.short}</p>
                </div>
                <span class="mt-1 text-ink-500 group-hover:text-brand-500"><Icon name="arrow-right" size={16} /></span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {/* CLOSING CTA */}
  <section class="bg-paper border-t border-line">
    <div class="container-x py-14 text-center">
      <Eyebrow>Drop in, send it in, or book us onsite</Eyebrow>
      <h2 class="mt-3 display-2 text-ink-900">
        {site.address.street}, {site.address.suburb} · {site.hoursDisplay[0].value}
      </h2>
      <div class="mt-8 inline-flex flex-wrap justify-center gap-3">
        <a href={site.phone.href} class="btn btn-primary">
          <Icon name="phone" size={18} /> Call {site.phone.display}
        </a>
        <a href="/contact" class="btn btn-outline">
          <Icon name="map-pin" size={18} /> Contact &amp; directions
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
