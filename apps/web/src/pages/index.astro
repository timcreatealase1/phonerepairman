---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Icon from '~/components/Icon.astro';
import { site, services } from '~/data/site';
import { serviceSchema, faqPageSchema } from '~/lib/seo/schema';

const title = `${site.name} — AWA-authorized device repair in Muswellbrook & the Upper Hunter`;
const description =
  'AWA-authorized HP, Acer and Lexmark repair agent and direct Epson partner in Muswellbrook. Walk-in phone, laptop, tablet and gaming repairs. Est. 2014.';

// Hero badges — short, scannable trust signals.
const heroBadges = [
  { icon: 'check' as const,       text: 'Walk-ins welcome' },
  { icon: 'clock' as const,       text: 'Same-day service' },
  { icon: 'shield-check' as const, text: 'AWA-authorized agent' },
  { icon: 'map-pin' as const,     text: `${site.address.suburb} · Est. ${site.yearFounded}` },
];

// Homepage FAQ — 4 starter Qs. Drives FAQPage schema and the on-page FAQ block.
const faqs = [
  {
    question: 'Do I need to book, or can I just walk in?',
    answer:
      'Walk-ins are welcome any time during opening hours. For laptops, gaming consoles and warranty work it helps to call ahead — that way we know parts are in stock and can usually book you in for a same-day return.',
  },
  {
    question: 'Are you actually authorized to repair HP, Acer, Lexmark and Epson?',
    answer:
      'Yes. Phone Repairman is an AWA-authorized service agent for HP, Acer and Lexmark, and a direct service partner with Epson. Warranty work for these brands routes through us via ARA/AWA — same coverage, no parcel shipping out of the Hunter.',
  },
  {
    question: 'How long does a repair take?',
    answer:
      'Most common phone repairs (screen, battery, charging port) are completed same-day when the part is in stock. Laptops and gaming consoles are typically 1–3 business days. We give you a written turnaround on drop-off.',
  },
  {
    question: 'Do you do data recovery?',
    answer:
      'Yes — recovery of photos, contacts and documents from broken or unresponsive phones, laptops, hard drives and USB devices. Bring the device in for a no-obligation assessment.',
  },
  {
    question: 'Do you service the Upper Hunter beyond Muswellbrook?',
    answer:
      'Yes. We serve Singleton, Scone, Aberdeen, Denman, Merriwa, Murrurundi and the broader Hunter Valley — both via drop-off at our Bridge Street shop and onsite for business customers.',
  },
];

const schemaNodes = [
  serviceSchema({
    name: 'Device Repair',
    description:
      'Phone, tablet, laptop and gaming console repairs in Muswellbrook NSW. AWA-authorized for HP, Acer and Lexmark; direct Epson partner.',
    serviceType: 'Consumer Electronics Repair',
    url: site.url,
  }),
  faqPageSchema(faqs),
];
---

<BaseLayout title={title} description={description} schemaNodes={schemaNodes}>
  {/* HERO */}
  <section
    class="relative overflow-hidden text-white"
    style="background-image: linear-gradient(135deg, #003d82 0%, #0057b8 100%);"
  >
    <div class="container-x py-14 sm:py-20 text-center">
      <p class="mb-3 text-sm font-medium uppercase tracking-widest text-white/70">
        Muswellbrook · Upper Hunter · since {site.yearFounded}
      </p>
      <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight">
        Authorized device repair, in your town.
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-base sm:text-lg text-white/90">
        Phone Repairman is the only <strong class="text-white">AWA-authorized HP, Acer and Lexmark</strong>
        repair agent — and direct Epson service partner — serving the Upper Hunter from
        Muswellbrook NSW.
      </p>

      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href={site.phone.href} class="btn btn-white">
          <Icon name="phone" size={18} /> Call {site.phone.display}
        </a>
        <a href={site.sms.href} class="btn btn-outline-white">
          <Icon name="message-circle" size={18} /> SMS us
        </a>
        <a href={site.address.directions} target="_blank" rel="noopener" class="btn btn-outline-white">
          <Icon name="directions" size={18} /> Directions
        </a>
      </div>

      <ul class="mt-10 flex flex-wrap items-center justify-center gap-x-6 gap-y-3 border-t border-white/15 pt-7 text-sm">
        {heroBadges.map((b) => (
          <li class="flex items-center gap-2 text-white/90">
            <Icon name={b.icon} size={16} />
            {b.text}
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* OPEN / CLOSED + SHORT NAP STRIP */}
  <section aria-label="Open status and location" class="border-b border-ink-900/10 bg-surface-tint">
    <div class="container-x flex flex-col items-center justify-between gap-3 py-4 sm:flex-row sm:gap-6 text-sm">
      <p class="flex items-center gap-2 text-ink-900">
        <Icon name="clock" size={16} class="text-brand-500" />
        <span id="open-status" class="font-semibold">Mon–Fri, 9:30am – 5:00pm</span>
      </p>
      <p class="flex items-center gap-2 text-ink-600">
        <Icon name="map-pin" size={16} class="text-brand-500" />
        {site.address.street}, {site.address.suburb} NSW {site.address.postcode}
      </p>
      <a href={site.phone.href} class="font-bold text-brand-500 hover:text-brand-700">
        {site.phone.display}
      </a>
    </div>
  </section>

  {/* SERVICES */}
  <section class="section bg-white">
    <div class="container-x">
      <h2 class="section-title">What we fix</h2>
      <p class="section-sub">Same-day where the part is in stock. Written turnaround on drop-off.</p>
      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((s) => (
          <a
            href={`/services/${s.slug}`}
            class="group rounded-xl border border-ink-900/10 bg-white p-6 shadow-card transition hover:-translate-y-0.5 hover:border-brand-200 hover:shadow-card-hover"
          >
            <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-lg bg-brand-50 text-brand-500">
              <Icon name={s.icon as any} size={22} />
            </div>
            <h3 class="text-lg font-bold text-ink-900">{s.name}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-600">{s.short}</p>
            <p class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-500 group-hover:gap-2 group-hover:transition-all">
              Learn more <Icon name="arrow-right" size={14} />
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* AUTHORIZATIONS STRIP */}
  <section class="section bg-surface-alt">
    <div class="container-x">
      <h2 class="section-title">Brand-authorized, not just brand-aware.</h2>
      <p class="section-sub">
        Warranty work for these brands is routed through us via the AWA / ARA partner network —
        same coverage as factory service, with no parcel shipping out of the Hunter.
      </p>
      <ul class="mx-auto mt-10 grid max-w-3xl gap-3 sm:grid-cols-2">
        {site.authorizations.map((a) => (
          <li class="flex items-start gap-3 rounded-lg border border-ink-900/10 bg-white p-4">
            <span class="mt-0.5 text-brand-500"><Icon name="shield-check" size={20} /></span>
            <div>
              <p class="font-bold text-ink-900">{a.brand}</p>
              <p class="text-sm text-ink-600">{a.kind}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* TRUST / REVIEWS */}
  <section class="section bg-white">
    <div class="container-x">
      <h2 class="section-title">What customers say</h2>
      <p class="section-sub">Real reviews from real customers across the Upper Hunter.</p>
      {/* TODO (Tim): replace with three real Google / FB reviews before launch. Phase 4 automates this. */}
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {[1, 2, 3].map(() => (
          <article class="rounded-xl border border-ink-900/10 bg-white p-6 shadow-card">
            <div class="flex gap-0.5 text-amber-400" aria-label="5 out of 5 stars">
              {[1, 2, 3, 4, 5].map(() => <Icon name="star" size={16} class="fill-current" />)}
            </div>
            <p class="mt-3 text-ink-900">
              {/* Placeholder copy — swap with a real customer quote. */}
              "Quick turnaround on my [device] — back in my pocket the same afternoon. Honest pricing
              and they explained what went wrong."
            </p>
            <p class="mt-4 text-sm font-semibold text-ink-600">— Customer, Muswellbrook</p>
          </article>
        ))}
      </div>
      <p class="mt-8 text-center text-sm text-ink-600">
        <a href={site.social.facebook} target="_blank" rel="noopener" class="font-semibold text-brand-500 hover:underline">
          See all reviews on Facebook →
        </a>
      </p>
    </div>
  </section>

  {/* BUSINESS / B2B HINT */}
  <section class="section bg-brand-500 text-white">
    <div class="container-x grid gap-6 lg:grid-cols-[2fr,1fr] lg:items-center">
      <div>
        <p class="text-sm font-medium uppercase tracking-widest text-white/70">For business</p>
        <h2 class="mt-2 text-2xl sm:text-3xl font-extrabold tracking-tight">
          Fleet repairs, onsite IT, and managed devices across the Hunter.
        </h2>
        <p class="mt-3 max-w-2xl text-white/90">
          Subcontract field-service for MSPs and OEM warranty channels. Bulk repairs for mines,
          councils and schools. Talk to Tim directly.
        </p>
      </div>
      <div class="flex flex-wrap gap-3 lg:justify-end">
        <a href={site.phone.href} class="btn btn-white">
          <Icon name="phone" size={18} /> {site.phone.display}
        </a>
        <a href={site.email.href} class="btn btn-outline-white">
          <Icon name="mail" size={18} /> Email Tim
        </a>
      </div>
    </div>
  </section>

  {/* FAQs */}
  <section class="section bg-white">
    <div class="container-x max-w-3xl">
      <h2 class="section-title">Common questions</h2>
      <p class="section-sub">Three minutes of reading that saves a phone call.</p>
      <div class="mt-8 divide-y divide-ink-900/10 rounded-xl border border-ink-900/10 bg-white">
        {faqs.map((f, i) => (
          <details class="group p-5" open={i === 0}>
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-bold text-ink-900">
              <span>{f.question}</span>
              <span class="text-brand-500 transition group-open:rotate-90"><Icon name="chevron-right" size={18} /></span>
            </summary>
            <p class="mt-3 leading-relaxed text-ink-600">{f.answer}</p>
          </details>
        ))}
      </div>
      <p class="mt-6 text-center text-sm text-ink-600">
        Still got a question? <a href="/faqs" class="font-semibold text-brand-500 hover:underline">See all FAQs</a> or
        <a href={site.phone.href} class="font-semibold text-brand-500 hover:underline"> call us</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  // Compute open/closed from the static weekday schedule. Replaced by a live
  // Zoho-backed endpoint in Phase 3.
  (function () {
    const el = document.getElementById('open-status');
    if (!el) return;
    const now = new Date();
    const day = now.getDay(); // 0 Sun .. 6 Sat
    const minsNow = now.getHours() * 60 + now.getMinutes();
    const open = 9 * 60 + 30;
    const close = 17 * 60;
    const isWeekday = day >= 1 && day <= 5;
    if (isWeekday && minsNow >= open && minsNow < close) {
      el.textContent = `Open now — closes 5:00pm`;
      el.classList.add('text-emerald-700');
    } else if (isWeekday && minsNow < open) {
      el.textContent = `Closed — opens 9:30am today`;
      el.classList.add('text-ink-600');
    } else {
      el.textContent = `Closed — opens 9:30am Monday`;
      el.classList.add('text-ink-600');
    }
  })();
</script>
