---
// Photo placeholder that swaps to a real <img> when `src` is supplied.
// Until Tim drops real shop / workbench / technician photos in /public/,
// this renders a tasteful holding-state with a mono caption so empty
// states look intentional, not broken.

interface Props {
  src?: string;
  alt: string;
  aspect?: '4/5' | '3/4' | '4/3' | '16/9' | '1/1';
  caption?: string;
  class?: string;
  loading?: 'eager' | 'lazy';
}

const {
  src,
  alt,
  aspect = '4/5',
  caption,
  class: className = '',
  loading = 'lazy',
} = Astro.props;

const aspectClass = {
  '4/5':  'aspect-[4/5]',
  '3/4':  'aspect-[3/4]',
  '4/3':  'aspect-[4/3]',
  '16/9': 'aspect-video',
  '1/1':  'aspect-square',
}[aspect];
---

{src ? (
  <figure class={`relative overflow-hidden rounded-md ${aspectClass} ${className}`}>
    <img src={src} alt={alt} loading={loading} class="h-full w-full object-cover" />
    {caption && (
      <figcaption class="absolute bottom-3 left-3 rounded bg-black/55 px-2 py-1 font-mono text-xs uppercase tracking-wider text-white">
        {caption}
      </figcaption>
    )}
  </figure>
) : (
  <div
    class={`relative overflow-hidden rounded-md border border-brand-200/60 ${aspectClass} ${className}`}
    style="background-image: linear-gradient(135deg, #e8f1fc 0%, #ffffff 50%, #d1e2f9 100%);"
    role="img"
    aria-label={alt}
  >
    <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 px-6 text-center">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0057b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
        <circle cx="9" cy="9" r="2"/>
        <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
      </svg>
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-brand-700">
        {caption ?? 'Photo coming soon'}
      </p>
    </div>
    <span class="absolute bottom-2 right-3 font-mono text-xs uppercase tracking-wider text-brand-700/70">
      {aspect}
    </span>
  </div>
)}
