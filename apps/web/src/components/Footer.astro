---
import { site } from '~/data/site';
import Icon from './Icon.astro';

const year = new Date().getFullYear();
---

<footer class="bg-ink-900 text-white/80">
  <div class="container-x py-14">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-[1.2fr,1fr,1fr,1fr]">
      <div>
        <img src="/wordmark-inverse.svg" alt={site.name} width="765" height="73" class="h-7 w-auto" />
        <p class="mt-6 max-w-sm font-mono text-xs uppercase tracking-[0.18em] text-white/60">
          Authorised device repair, in your town.
        </p>
      </div>

      <div>
        <h3 class="font-mono text-xs font-medium uppercase tracking-[0.18em] text-white/60">Find us</h3>
        <p class="mt-3 leading-relaxed text-white">
          {site.address.street}<br />
          {site.address.suburb} {site.address.state} {site.address.postcode}
        </p>
        <a
          href={site.address.directions}
          target="_blank"
          rel="noopener"
          class="mt-3 inline-flex items-center gap-1.5 text-sm text-white/80 hover:text-white"
        >
          <Icon name="directions" size={16} /> Get directions
        </a>

        <h3 class="mt-8 font-mono text-xs font-medium uppercase tracking-[0.18em] text-white/60">Hours</h3>
        <dl class="mt-3 space-y-1 text-white text-sm">
          {site.hoursDisplay.map((h) => (
            <div class="flex justify-between gap-4">
              <dt class="text-white/70">{h.label}</dt>
              <dd>{h.value}</dd>
            </div>
          ))}
        </dl>
      </div>

      <div>
        <h3 class="font-mono text-xs font-medium uppercase tracking-[0.18em] text-white/60">Contact</h3>
        <ul class="mt-3 space-y-2 text-white">
          <li>
            <a href={site.phone.href} class="inline-flex items-center gap-2 hover:text-brand-50">
              <Icon name="phone" size={16} /> {site.phone.display}
            </a>
          </li>
          <li>
            <a href={site.sms.href} class="inline-flex items-center gap-2 hover:text-brand-50">
              <Icon name="message-circle" size={16} /> SMS {site.sms.display}
            </a>
          </li>
          <li>
            <a href={site.email.href} class="inline-flex items-center gap-2 break-all hover:text-brand-50">
              <Icon name="mail" size={16} /> {site.email.display}
            </a>
          </li>
          <li>
            <a href={site.messenger.href} target="_blank" rel="noopener" class="inline-flex items-center gap-2 hover:text-brand-50">
              <Icon name="message-circle" size={16} /> Facebook Messenger
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="font-mono text-xs font-medium uppercase tracking-[0.18em] text-white/60">We accept</h3>
        <p class="mt-3 leading-relaxed text-white text-sm">
          {site.paymentAccepted.join(' · ')}
        </p>
        <h3 class="mt-8 font-mono text-xs font-medium uppercase tracking-[0.18em] text-white/60">Authorised for</h3>
        <p class="mt-3 leading-relaxed text-white text-sm">
          {site.authorizations.map((a) => a.brand).join(' · ')}
        </p>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container-x flex flex-col items-center justify-between gap-3 py-5 text-xs text-white/60 sm:flex-row">
      <p class="font-mono uppercase tracking-[0.16em]">
        &copy; {year} {site.name} · {site.address.suburb} NSW · Est. {site.yearFounded}
      </p>
      <p class="flex flex-wrap items-center justify-center gap-4">
        <a href="/privacy-policy" class="font-mono uppercase tracking-[0.16em] hover:text-white">Privacy</a>
        <a href={site.email.href} class="hover:text-white">{site.email.display}</a>
      </p>
    </div>
  </div>
</footer>
