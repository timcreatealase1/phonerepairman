---
import { site } from '~/data/site';
import Icon from './Icon.astro';

const year = new Date().getFullYear();
---

<footer class="bg-ink-900 text-white/80">
  <div class="container-x grid gap-10 py-12 sm:grid-cols-2 lg:grid-cols-4">
    <div>
      <h3 class="text-xs font-bold uppercase tracking-widest text-white/60">Find Us</h3>
      <p class="mt-3 leading-relaxed text-white">
        {site.address.street}<br />
        {site.address.suburb} {site.address.state} {site.address.postcode}<br />
        <span class="text-sm text-white/60">{site.address.note}</span>
      </p>
      <a
        href={site.address.directions}
        target="_blank"
        rel="noopener"
        class="mt-3 inline-flex items-center gap-1.5 text-sm text-white/80 hover:text-white"
      >
        <Icon name="directions" size={16} /> Get directions
      </a>
    </div>

    <div>
      <h3 class="text-xs font-bold uppercase tracking-widest text-white/60">Hours</h3>
      <dl class="mt-3 space-y-1 text-white">
        {site.hoursDisplay.map((h) => (
          <div class="flex justify-between gap-4">
            <dt class="text-white/70">{h.label}</dt>
            <dd>{h.value}</dd>
          </div>
        ))}
      </dl>
    </div>

    <div>
      <h3 class="text-xs font-bold uppercase tracking-widest text-white/60">Contact</h3>
      <ul class="mt-3 space-y-2 text-white">
        <li>
          <a href={site.phone.href} class="inline-flex items-center gap-2 hover:text-brand-50">
            <Icon name="phone" size={16} /> {site.phone.display}
          </a>
        </li>
        <li>
          <a href={site.sms.href} class="inline-flex items-center gap-2 hover:text-brand-50">
            <Icon name="message-circle" size={16} /> SMS {site.sms.display}
          </a>
        </li>
        <li>
          <a href={site.email.href} class="inline-flex items-center gap-2 break-all hover:text-brand-50">
            <Icon name="mail" size={16} /> {site.email.display}
          </a>
        </li>
        <li>
          <a href={site.messenger.href} target="_blank" rel="noopener" class="inline-flex items-center gap-2 hover:text-brand-50">
            <Icon name="message-circle" size={16} /> Facebook Messenger
          </a>
        </li>
      </ul>
    </div>

    <div>
      <h3 class="text-xs font-bold uppercase tracking-widest text-white/60">We Accept</h3>
      <p class="mt-3 leading-relaxed text-white">
        {site.paymentAccepted.join(' · ')}
      </p>
      <h3 class="mt-6 text-xs font-bold uppercase tracking-widest text-white/60">Authorized For</h3>
      <p class="mt-3 leading-relaxed text-white">
        {site.authorizations.map((a) => a.brand).join(' · ')}
      </p>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container-x flex flex-col items-center justify-between gap-2 py-5 text-xs text-white/60 sm:flex-row">
      <p>&copy; {year} {site.name} · {site.address.suburb} NSW · Est. {site.yearFounded}</p>
      <p><a href={site.email.href} class="hover:text-white">{site.email.display}</a></p>
    </div>
  </div>
</footer>
