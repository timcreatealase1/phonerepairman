---
import { site } from '~/data/site';
import Icon from './Icon.astro';
---

<header class="sticky top-0 z-40 border-b border-line bg-paper/85 backdrop-blur supports-[backdrop-filter]:bg-paper/75">
  <div class="container-x flex h-[60px] items-center justify-between">
    <a href="/" class="flex items-center gap-2.5" aria-label={site.name}>
      {/* Mark + wordmark — use mark on tiny screens, full lockup elsewhere */}
      <img src="/logo-mark.svg" alt="" width="28" height="28" class="block sm:hidden" />
      <img src="/logo-full.svg" alt={site.name} width="160" height="40" class="hidden sm:block h-9 w-auto" />
    </a>

    <nav class="hidden items-center gap-6 md:flex" aria-label="Primary">
      <a href="/services/" class="mono-nav">Services</a>
      <a href="/about" class="mono-nav">About</a>
      <a href="/faqs" class="mono-nav">FAQs</a>
      <a href="/contact" class="mono-nav">Contact</a>
    </nav>

    <a
      href={site.phone.href}
      class="hidden items-center gap-2 text-brand-500 hover:text-brand-700 sm:inline-flex"
    >
      <Icon name="phone" size={18} />
      <span class="font-bold">{site.phone.display}</span>
    </a>
  </div>
</header>
