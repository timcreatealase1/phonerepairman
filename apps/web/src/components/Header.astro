---
import { site } from '~/data/site';
import Icon from './Icon.astro';
---

<header class="sticky top-0 z-40 border-b border-ink-900/10 bg-white/95 backdrop-blur supports-[backdrop-filter]:bg-white/80">
  <div class="container-x flex h-16 items-center justify-between">
    <a href="/" class="flex items-baseline gap-0 text-lg font-extrabold tracking-tight">
      <span class="text-brand-500">Phone</span><span class="text-ink-900">Repairman</span>
    </a>

    <nav class="hidden items-center gap-6 text-sm font-medium text-ink-600 md:flex" aria-label="Primary">
      <a href="/services/" class="hover:text-ink-900">Services</a>
      <a href="/about" class="hover:text-ink-900">About</a>
      <a href="/faqs" class="hover:text-ink-900">FAQs</a>
      <a href="/contact" class="hover:text-ink-900">Contact</a>
    </nav>

    <a
      href={site.phone.href}
      class="hidden items-center gap-2 text-brand-500 hover:text-brand-700 sm:inline-flex"
    >
      <Icon name="phone" size={18} />
      <span class="font-bold">{site.phone.display}</span>
    </a>
  </div>
</header>
