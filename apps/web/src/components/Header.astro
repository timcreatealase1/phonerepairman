---
import { site } from '~/data/site';
import Icon from './Icon.astro';
---

<header class="sticky top-0 z-40 border-b border-line bg-paper/85 backdrop-blur supports-[backdrop-filter]:bg-paper/75">
  <div class="container-x flex h-[60px] items-center justify-between gap-4">
    <a href="/" class="flex items-center" aria-label={site.name}>
      <img
        src="/wordmark.png"
        alt={site.name}
        width="765"
        height="73"
        class="h-5 w-auto sm:h-6 md:h-7"
      />
    </a>

    <nav class="hidden items-center gap-5 lg:flex" aria-label="Primary">
      <a href="/services/" class="mono-nav">Services</a>
      <a href="/brands/" class="mono-nav">Brands</a>
      <a href="/locations/" class="mono-nav">Locations</a>
      <a href="/about" class="mono-nav">About</a>
      <a href="/faqs" class="mono-nav">FAQs</a>
      <a href="/contact" class="mono-nav">Contact</a>
    </nav>

    <a
      href={site.phone.href}
      class="hidden items-center gap-2 text-brand-500 hover:text-brand-700 sm:inline-flex"
    >
      <Icon name="phone" size={18} />
      <span class="font-bold">{site.phone.display}</span>
    </a>
  </div>
</header>
