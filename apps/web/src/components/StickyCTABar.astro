---
import { site } from '~/data/site';
import Icon from './Icon.astro';

const items = [
  { label: 'Call',   href: site.phone.href,       icon: 'phone' as const },
  { label: 'SMS',    href: site.sms.href,         icon: 'message-circle' as const },
  { label: 'Map',    href: site.address.directions, icon: 'map-pin' as const, external: true },
  { label: 'Message', href: site.messenger.href,  icon: 'mail' as const,     external: true },
];
---

<nav
  class="fixed inset-x-0 bottom-0 z-50 grid grid-cols-4 border-t border-ink/10 bg-white shadow-[0_-2px_10px_rgba(0,0,0,0.06)] md:hidden"
  aria-label="Quick actions"
>
  {items.map((it) => (
    <a
      href={it.href}
      target={it.external ? '_blank' : undefined}
      rel={it.external ? 'noopener' : undefined}
      class="flex flex-col items-center justify-center gap-1 py-2.5 text-[0.7rem] font-semibold uppercase tracking-wide text-ink hover:bg-brand-50 active:bg-brand-100"
    >
      <Icon name={it.icon} size={22} class="text-brand-500" />
      {it.label}
    </a>
  ))}
</nav>
